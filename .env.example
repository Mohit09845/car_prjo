# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/car_db?retryWrites=true&w=majority

# API key used by the X-API-Key request header
API_KEY=<your-api-key>

# NVIDIA NIM API key for the LLM intent parser
NVIDIA_API_KEY=<your-nvidia-api-key>
